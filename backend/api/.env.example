# Application Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/dcs?retryWrites=true&w=majority

# Authentication Secrets
JWT_SECRET=generate_a_secure_random_string_here
JWT_EXPIRES_IN=7d

# Cloudflare R2 Credentials
R2_ENDPOINT=https://65664a68602fa3aeaf1afbc93cd574f3.r2.cloudflarestorage.com
R2_ACCESS_KEY=your_cloudflare_r2_access_key_id
R2_SECRET_KEY=your_cloudflare_r2_secret_access_key
R2_BUCKET_NAME=dcs-files
